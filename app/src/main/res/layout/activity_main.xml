<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:background="@color/background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            tools:context=".MainActivity">


        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginBottom="16dp"
            android:background="@color/background"
            android:elevation="0dp"
            app:logo="@mipmap/ic_launcher_round"
            app:contentInsetStart="0dp"
            app:contentInsetStartWithNavigation="0dp"
            app:titleTextColor="@color/turquoise"
            app:menu="@menu/menu_main"
            app:title="TagSafe" />

        <TextView
            android:id="@+id/textViewBemVindo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Olá, Professor!"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- ========================================== -->
        <!-- ESTADO 1: CRIAÇÃO DE AULA -->
        <!-- ========================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutCriacaoAula"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/surface"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/textViewTituloCriacao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="Nova Atividade"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- Seleção de Empresa -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Empresa"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="@color/turquoise"
                    app:startIconDrawable="@drawable/ic_business"
                    app:startIconTint="@color/turquoise">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerEmpresa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Seleção de Unidade -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Unidade"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" 
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutSpinnerUnidade"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="@color/turquoise"
                    app:startIconDrawable="@drawable/ic_location"
                    app:startIconTint="@color/turquoise">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerUnidade"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:inputType="none"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Selecao modulo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Modulo"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutSpinnerModule"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="@color/turquoise"
                    app:startIconDrawable="@drawable/ic_description"
                    app:startIconTint="@color/turquoise">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerModule"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:inputType="none"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campos de Treinamento -->
                <LinearLayout
                    android:id="@+id/layoutTreinamentoFields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Nome do treinamento"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/turquoise"
                        app:endIconMode="dropdown_menu"
                        app:startIconDrawable="@drawable/ic_description"
                        app:startIconTint="@color/turquoise">

                        <AutoCompleteTextView
                            android:id="@+id/editTextNomeTreinamento"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:completionThreshold="1"
                            android:hint="Ex: NR-35"
                            android:inputType="textCapWords"
                            android:maxLength="80"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Descrição -->
                <TextView
                    android:id="@+id/textViewDescricaoLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Descrição"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutDescricaoAula"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:visibility="gone"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="@color/turquoise"
                    app:counterEnabled="true"
                    app:counterMaxLength="100"
                    app:startIconDrawable="@drawable/ic_description"
                    app:startIconTint="@color/turquoise">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextDescricaoAula"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences"
                        android:maxLength="100"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botão Iniciar Aula -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonIniciarAula"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Iniciar atividade"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/turquoise"
                    app:cornerRadius="16dp"
                    app:elevation="6dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ========================================== -->
        <!-- ESTADO 2: LEITURA DE NFC -->
        <!-- ========================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutLeituraNFC"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/surface"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Header da Aula em Andamento -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/textViewAulaEmAndamento"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aula em Progresso"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/turquoise"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/textViewDescricaoAtual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alongamento para equipe de TI"
                        android:textSize="16sp"
                        android:textColor="@color/text_secondary"
                        android:textAlignment="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/textViewUnidadeAtual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unidade: BASF - Planta 1"
                        android:textSize="14sp"
                        android:textColor="@color/text_tertiary"
                        android:textAlignment="center" />

                </LinearLayout>

                <!-- Card de Instrução NFC -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/turquoise_light"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/turquoise"
                    android:layout_marginBottom="32dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="32dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:src="@drawable/ic_nfc"
                            app:tint="@color/turquoise"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aproxime o crachá NFC"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/turquoise"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="para registrar presença"
                            android:textSize="16sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Lista de NFCs Lidos -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="IDs Registrados"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/surface_variant"
                    android:layout_marginBottom="12dp">

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:padding="16dp"
                        android:fadeScrollbars="false"
                        android:scrollbarThumbVertical="@color/turquoise"
                        android:scrollbars="vertical"
                        android:nestedScrollingEnabled="true">

                        <TextView
                            android:id="@+id/textViewListaNFCs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nenhum crachá lido ainda."
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/text_secondary" />

                    </ScrollView>

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/textViewContador"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Participantes registrados: 0"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="24dp"
                    android:gravity="center" />

                <!-- Botões de Ação -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonConfirmarAula"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Confirmar Aula"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:backgroundTint="@color/turquoise"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonAbortarAula"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Abortar Aula"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@color/error"
                    app:strokeWidth="2dp"
                    android:textColor="@color/error" />

                <TextView
                    android:id="@+id/textViewDuracaoAula"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Duração: 00:00:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/textViewAvisoAula"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="A atividade permanecerá aberta até o encerramento manual, permitindo assim a contabilização das horas"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:gravity="center" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/statusBarScrim"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="top"
        android:background="@color/turquoise" />

</FrameLayout>
